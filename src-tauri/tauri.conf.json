{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Liauth",
  "version": "0.1.3",
  "identifier": "org.nanto.liauth",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Liauth",
        "width": 1100,
        "height": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Owner",
        "mimeType": "text/markdown"
      }
    ],
    "macOS": {
      "signingIdentity": "-",
      "files": {
        "Resources/markdown.icns": "icons/markdown.icns"
      },
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI5MURBOUFEQUQzMzJGOTkKUldTWkx6T3RyYWtkdWRYcGJ5cFRLYzl2Q1FvNE51RUxoWGdGZU0yWkNTOEozZWd4WVpuQ1VEWDQK",
      "endpoints": [
        "https://github.com/autholykos/liauth/releases/latest/download/latest.json"
      ]
    }
  }
}
